# Azure OpenAI — drives the conversation. Without these the agent will refuse turns.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_MODEL=gpt-4o
AZURE_OPENAI_SUBSCRIPTION_KEY=
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Cartesia STT + TTS — required for full voice experience.
# Without these, the API returns text only and the frontend falls back to
# browser SpeechSynthesis for output (no STT fallback).
CARTESIA_API_KEY=

# Optional overrides
CARTESIA_VOICE_ID=694f9389-aac1-45b6-b726-9d9369183238
CARTESIA_TTS_MODEL=sonic-2
CARTESIA_STT_MODEL=ink-whisper
CARTESIA_VERSION=2024-11-13
